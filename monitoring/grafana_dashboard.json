{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Quant Platform metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "A-Share Quant Platform monitoring dashboard. Auto-generated from /api/metrics endpoint.",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Stage Duration",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(pipeline_stage_duration_seconds_sum[5m]) / rate(pipeline_stage_duration_seconds_count[5m])",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Pipeline Stage Invocations",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pipeline_stage_total",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "title": "Pipeline Errors",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "pipeline_stage_errors_total",
          "legendFormat": "{{stage}}: {{error}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(api_requests_total[5m])",
          "legendFormat": "{{endpoint}} {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "API Latency P95",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(api_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(api_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Data Provider Health",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "data_provider_success_total",
          "legendFormat": "{{provider}}",
          "instant": true
        }
      ]
    },
    {
      "title": "Data Provider Failures",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(data_provider_failures_total[5m])",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "title": "Active Positions",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "trading_active_positions",
          "legendFormat": "positions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 500,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },
    {
      "title": "Portfolio P&L",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 22 },
      "targets": [
        {
          "expr": "trading_portfolio_pnl",
          "legendFormat": "P&L"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyCNY" }
      }
    },
    {
      "title": "Risk Level",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "risk_level",
          "legendFormat": "level"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "GREEN", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "YELLOW", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "ORANGE", "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "RED", "color": "red" } } },
            { "type": "value", "options": { "4": { "text": "KILL", "color": "dark-red" } } }
          ]
        }
      }
    },
    {
      "title": "Kill Switch",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 22 },
      "targets": [
        {
          "expr": "risk_kill_switch_active",
          "legendFormat": "Kill Switch"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "ARMED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "TRIGGERED", "color": "dark-red" } } }
          ]
        }
      }
    },
    {
      "title": "Factor IC Decay Monitor",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "factor_ic_value",
          "legendFormat": "{{factor}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "green", "value": 0.03 }
            ]
          }
        }
      }
    },
    {
      "title": "ML Model Performance",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "ml_model_test_ic",
          "legendFormat": "{{model_type}} IC"
        },
        {
          "expr": "ml_model_test_icir",
          "legendFormat": "{{model_type}} ICIR"
        }
      ]
    },
    {
      "title": "EventBus Throughput",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "rate(eventbus_events_published_total[5m])",
          "legendFormat": "published/s"
        },
        {
          "expr": "rate(eventbus_events_delivered_total[5m])",
          "legendFormat": "delivered/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "EventBus Dead Letters",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "eventbus_dead_letters_total",
          "legendFormat": "dead letters"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "SQLite Store Stats",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 36 },
      "targets": [
        {
          "expr": "store_orders_total",
          "legendFormat": "Orders"
        },
        {
          "expr": "store_trades_total",
          "legendFormat": "Trades"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["quant", "trading", "a-share"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "Quant Platform Monitor",
  "uid": "quant-platform-main",
  "version": 1
}
